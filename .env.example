# PostHog Analytics (optional — analytics disabled when unset)
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=

# ── Discord ──────────────────────────────────────────────────────────────────
# Two independent Discord integrations share ONE Discord application (reuse the
# existing open-core-server app for both). Set these in Vercel.
#
#   1. Pro role sync + the account-page "Connect Discord" card. Links an
#      already-signed-in customer's Discord account and grants the Pro role.
#      The card only renders when all of the following are set:
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PRO_ROLE_ID=
MEDUSA_ADMIN_API_TOKEN=
#      Optional: slash-command signature verification (Discord-first /link, not
#      yet shipped) and the secret guarding the reconcile cron.
DISCORD_PUBLIC_KEY=
CRON_SECRET=
#
#   2. "Sign in with Discord" button on the login page. This goes through a
#      Medusa `discord` auth provider (see the wcpos-medusa repo). Set to 'true'
#      ONLY after that provider is deployed, or the button errors.
DISCORD_LOGIN_ENABLED=
