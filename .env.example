# PostHog Analytics (optional — analytics disabled when unset)
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_POSTHOG_KEY=
POSTHOG_API_KEY=

# ── Checkout gateway (server-to-server) ─────────────────────────────────────
# Runtime-only shared secrets sent by wcpos.com when asking the host-selected
# Medusa backend to allocate a payment session. Configure each same-named 32+
# character value on its matching Medusa service. Both are REQUIRED on the
# production Vercel deployment. Never expose either through NEXT_PUBLIC_.
CHECKOUT_GATEWAY_SECRET_LIVE=
CHECKOUT_GATEWAY_SECRET_TEST=

# ── Discord ──────────────────────────────────────────────────────────────────
# Two independent Discord integrations share ONE Discord application (reuse the
# existing open-core-server app for both). Set these in Vercel.
#
#   1. Pro connected-member access. Discord users claim a licence key through
#      OAuth identify and receive the Pro role while that licence is active.
#      Reconciliation enumerates licence metadata via Medusa admin orders.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_PRO_ROLE_ID=
# Locked #member-directory channel (owner + bot only); leave empty to disable the directory.
DISCORD_DIRECTORY_CHANNEL_ID=
MEDUSA_ADMIN_API_TOKEN=
# Medusa admin key used by the launch verification drill.
MEDUSA_API_KEY=
#      Interactions endpoint (/api/discord/interactions: /link, /unlink,
#      "Customer info") verifies request signatures with the application
#      public key — Discord dev portal → General Information → Public Key,
#      or GET /applications/@me `verify_key`. The endpoint 503s without it.
#      Register the commands with `pnpm discord:register-commands`.
DISCORD_PUBLIC_KEY=
#      Secret guarding the reconcile cron.
CRON_SECRET=
#
#   2. "Sign in with Discord" login button — needs no env here. It is always
#      shown (like Google/GitHub) and authenticates through the Medusa `discord`
#      auth provider (configured in the wcpos-medusa repo).

# ── Logging & alerting (src/instrumentation.ts, src/lib/sinks/*) ──────────────
# LogTape fans out to Console (always), Loki, Sentry, Discord and email. Discord
# and email only fire on error/fatal; each sink is skipped when its env is unset.
LOKI_URL=
LOKI_API_KEY=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# debug | info | warning | error | fatal (client-side; default error in prod)
NEXT_PUBLIC_LOG_LEVEL=
# Discord channel webhook — receives all error/fatal alerts (money-at-risk and
# download-delivery failures bypass the per-category rate limit).
DISCORD_WEBHOOK_URL=
# Owner alert EMAIL for the immediate-attention tier (fatal only). Posts to the
# Resend REST API. ALERT_EMAIL_TO may be a comma-separated list.
RESEND_API_KEY=
ALERT_EMAIL_FROM="WCPOS Alerts <noreply@wcpos.com>"
ALERT_EMAIL_TO=
# Guards /api/debug/alert-test in production (validates the Discord+email chain).
ALERT_TEST_TOKEN=

# ── Pro downloads & licensing (Keygen) ───────────────────────────────────────
# HMAC secret for the 60s signed download token. REQUIRED in production.
# If unset, download routes fall back to KEYGEN_API_TOKEN; when neither secret
# is configured, they log an error and return 500.
DOWNLOAD_TOKEN_SECRET=
KEYGEN_HOST=license.wcpos.com
KEYGEN_API_TOKEN=

# ── Rate limiting (Upstash Redis) ────────────────────────────────────────────
# Backs the support box, the checkout report-failure beacon, and the download
# token gate. Both variables are REQUIRED in production. Legacy callers remain
# fail-open, while protected registration and payment-session mutations fail
# closed when Redis is unconfigured, times out, or errors.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Cloudflare Turnstile ─────────────────────────────────────────────────────
# Server-side secret for live bot verification. REQUIRED in production;
# protected registration mutations fail closed when verification is unavailable.
TURNSTILE_SECRET_KEY=

# ── Square Terminal connect relay ────────────────────────────────────────────
#   Square permits ONE registered redirect URL per application, so this site
#   receives the OAuth callback for the Square Terminal plugin and forwards it
#   to the merchant's own site. That is the only reason it exists.
#
#   No Square application secret is held here and no token ever reaches this
#   service: the plugin uses PKCE and keeps the code verifier on its own site,
#   so a code passing through here cannot be exchanged by us or by anyone
#   observing it.
#
#   Application IDs are PUBLIC — PKCE is what makes them safe to ship. Square
#   issues a separate ID per environment and rejects one used against the other,
#   so one deployment serves both by picking the matching ID per request.
#   Set only the environments you support; /api/square/session returns 503 for
#   an environment whose ID is unset.
#   Found at: developer.squareup.com/apps → your app → OAuth → Application ID
#   (toggle Sandbox/Production at the top of the page first)
SQUARE_CONNECT_CLIENT_ID=
SQUARE_CONNECT_SANDBOX_CLIENT_ID=
#   Signs the OAuth state so a caller cannot redirect a live authorization code
#   to a site of their choosing. Not obtained from Square — generate one:
#     openssl rand -base64 32
SQUARE_CONNECT_STATE_SECRET=
