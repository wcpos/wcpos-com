{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "regions": [
    "fra1"
  ],
  "installCommand": "pnpm install",
  "buildCommand": "pnpm build",
  "devCommand": "pnpm dev",
  "git": {
    "deploymentEnabled": {
      "main": false,
      "staging": false
    }
  },
  "crons": [
    {
      "path": "/api/discord/reconcile",
      "schedule": "0 3 * * *"
    }
  ]
}
